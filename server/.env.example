# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgres://fraise:fraise@localhost:5432/fraise

# JWT signing secret — minimum 32 characters
# Generate: openssl rand -base64 32
JWT_SECRET=

# Staff JWT signing secret — separate key, minimum 32 characters
# Structural isolation: a user token cannot decode as a StaffClaims token
STAFF_JWT_SECRET=

# Stripe — required even without active payments (startup validation)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Operator PINs — minimum 8 characters, not all the same character
ADMIN_PIN=
CHOCOLATIER_PIN=
SUPPLIER_PIN=

# ── Optional: core ────────────────────────────────────────────────────────────

# HTTP port (default: 3001)
PORT=3001

# Publicly reachable base URL — used in email links and OAuth redirects
# e.g. https://your-api.up.railway.app
API_BASE_URL=http://localhost:3001

# Redis — enables distributed nonce deduplication for replay prevention.
# Without Redis, an in-process HashMap is used (single instance only).
REDIS_URL=redis://localhost:6379

# iOS HMAC shared key — fallback for non-attested iOS clients.
# If absent, requests without an App Attest key are rejected.
FRAISE_HMAC_SHARED_KEY=

# Apple App Store numeric ID (e.g. 6478901234)
# When set, the NFC sticker fallback page includes a real App Store link.
APP_STORE_ID=

# Review PIN for Apple App Review demo account (optional)
REVIEW_PIN=

# ── Optional: email ───────────────────────────────────────────────────────────

# Resend API key — enables verification emails, password reset, order confirmations
RESEND_API_KEY=

# ── Optional: Apple Sign In ───────────────────────────────────────────────────

APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=
# PEM-encoded private key (ES256) — newlines replaced with \n
APPLE_PRIVATE_KEY=

# ── Optional: Square ─────────────────────────────────────────────────────────
# When SQUARE_APP_ID is set, SQUARE_ORDER_WEBHOOK_SIGNING_KEY and
# SQUARE_ORDER_NOTIFICATION_URL become required (Config::load() will fail).

SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_OAUTH_REDIRECT_URL=https://your-api.up.railway.app/api/square/oauth/callback
SQUARE_ORDER_WEBHOOK_SIGNING_KEY=
SQUARE_ORDER_NOTIFICATION_URL=https://your-api.up.railway.app/api/webhooks/square/orders

# AES-256-GCM key for encrypting Square OAuth tokens at rest.
# Generate: openssl rand -hex 32
SQUARE_TOKEN_ENCRYPTION_KEY=

# ── Optional: Stripe Connect ──────────────────────────────────────────────────

# Platform fee on venue drink orders in basis points (default: 500 = 5%)
PLATFORM_FEE_BIPS=500

# ── Optional: media ───────────────────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Optional: AI ─────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=
