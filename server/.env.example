# box-fraise-platform server — environment variables
#
# Copy to .env and fill in values before running locally.
# Required variables will cause the server to refuse to start if absent.
# Optional variables degrade gracefully: the feature they power is disabled.
#
# Generate random secrets with:
#   openssl rand -base64 48

# ── Database ──────────────────────────────────────────────────────────────────

# Required. PostgreSQL connection string.
DATABASE_URL=postgres://user:password@localhost:5432/fraise_dev

# ── JWT signing ───────────────────────────────────────────────────────────────

# Required. HS256 key for user JWTs. Min 32 chars. Rotate with JWT_SECRET_PREVIOUS.
JWT_SECRET=replace-with-openssl-rand-base64-48

# Optional. Previous JWT key during rotation window only.
# JWT_SECRET_PREVIOUS=

# Required. Separate key for staff JWTs. Min 32 chars.
STAFF_JWT_SECRET=replace-with-openssl-rand-base64-48

# Optional. Previous staff JWT key during rotation window.
# STAFF_JWT_SECRET_PREVIOUS=

# ── Admin PINs ────────────────────────────────────────────────────────────────
# Sent as X-Admin-Pin header. Min 8 chars, not all same character.
# Hashed with bcrypt at startup; raw values discarded after boot.

# Required. Full admin access.
ADMIN_PIN=change-me-admin-pin

# Required. Catalog + order management only.
CHOCOLATIER_PIN=change-me-choc-pin

# Required. Read-only order list only.
SUPPLIER_PIN=change-me-supp-pin

# Optional. Apple App Review demo account PIN.
# REVIEW_PIN=

# ── Stripe ────────────────────────────────────────────────────────────────────

# Required. Starts with sk_test_ or sk_live_.
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Required. Starts with whsec_.
# Get from: dashboard.stripe.com → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Redis ─────────────────────────────────────────────────────────────────────

# Optional. Required before scaling to multiple instances.
# Without it: in-process nonce cache (single instance only).
# REDIS_URL=redis://localhost:6379

# ── Apple Sign In / App Attest ────────────────────────────────────────────────
# All four required together or Apple Sign In is unavailable.
# Get from: developer.apple.com → Certificates, Identifiers & Profiles

# APPLE_TEAM_ID=ABCDE12345
# APPLE_KEY_ID=ABCDE12345
# APPLE_CLIENT_ID=com.boxfraise.signin
# APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ── iOS request signing ───────────────────────────────────────────────────────

# Optional. HMAC-SHA256 shared key for non-attested iOS clients.
# Without it: requests without X-Fraise-Attest-Key are rejected.
# Generate: openssl rand -base64 32
# FRAISE_HMAC_SHARED_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────

# Optional. Without it: emails are skipped silently.
# Get from: resend.com → API Keys
# RESEND_API_KEY=re_...

# ── Anthropic (Dorotka AI) ────────────────────────────────────────────────────

# Optional. Without it: /api/dorotka/ask returns 500.
# Get from: console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudinary (media uploads) ────────────────────────────────────────────────

# Optional. All three required together.
# Get from: cloudinary.com → Settings → Access Keys
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Square (POS integration) ──────────────────────────────────────────────────
# When SQUARE_APP_ID is set, the two webhook vars below are also required
# (server refuses to start without them).
# Get from: developer.squareup.com → Applications

# SQUARE_APP_ID=
# SQUARE_APP_SECRET=
# SQUARE_OAUTH_REDIRECT_URL=https://your-api.railway.app/api/square/oauth/callback
# Generate: openssl rand -hex 32
# SQUARE_TOKEN_ENCRYPTION_KEY=
# SQUARE_ORDER_WEBHOOK_SIGNING_KEY=
# SQUARE_ORDER_NOTIFICATION_URL=https://your-api.railway.app/api/webhooks/square/orders

# ── Platform config ───────────────────────────────────────────────────────────

# Optional. Publicly reachable base URL for links in transactional emails.
# Default: http://localhost:3001
# API_BASE_URL=https://api.fraise.box

# Optional. Server port. Default: 3001
# PORT=3001

# Optional. Platform fee on venue drink orders in basis points (500 = 5%). Default: 500.
# PLATFORM_FEE_BIPS=500

# Optional. Apple App Store numeric ID — shown on the NFC fallback page.
# APP_STORE_ID=

# Optional. Email for operational alerts.
# OPERATOR_EMAIL=ops@example.com
